# Copy to .env.local and fill in your Neon connection string
DATABASE_URL=postgres://USER:PASSWORD@HOST/dbname?sslmode=require
JWT_SECRET=replace-me-with-a-long-random-string

# SaleBot — вебхук для рассылок (регистрация/бронь). Оставьте пустым, чтобы отключить.
SALEBOT_WEBHOOK_URL=

# Resend — отправка кодов на почту (рега/2FA). Домен в EMAIL_FROM должен быть verified в Resend.
RESEND_API_KEY=
EMAIL_FROM=AURIX MOTORS <noreply@aurixmotors.ru>

# Telegram — заявки с формы «Оставьте заявку» приходят в чат/группу.
# TELEGRAM_BOT_TOKEN — токен бота от @BotFather.
# TELEGRAM_CHAT_ID — id чата/группы (узнать: добавить бота в чат и открыть
#   https://api.telegram.org/bot<TOKEN>/getUpdates — там chat.id; для групп он с минусом).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
